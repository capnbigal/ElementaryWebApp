@page "/tool-slot-configurations"
@inject ToolSlotConfigurationService Service
@inject ISnackbar Snackbar

<PageTitle>Tool Slot Configurations</PageTitle>

<div class="tsc-page">
    <MudText Typo="Typo.h5" Class="mb-3">Tool Slot Configurations</MudText>

    <MudPaper Elevation="0" Class="mb-2 pa-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@(_editingItem is not null && !IsRowValid(_editingItem))"
                       OnClick="AddNewAsync">
                Add New
            </MudButton>

            <MudTextField T="string"
                          @bind-Value="_search"
                          Placeholder="Search all columns..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Disabled="@(_editingItem is not null)"
                          Class="flex-grow-1" />
        </MudStack>
    </MudPaper>

    <MudDataGrid @ref="_grid"
                 T="ToolSlotConfigurationDTO"
                 Class="tsc-stable-cols"
                 Items="_items"
                 Loading="_loading"
                 ReadOnly="true"
                 Filterable="true"
                 FilterMode="DataGridFilterMode.ColumnFilterMenu"
                 SortMode="SortMode.Multiple"
                 Hover="true"
                 Dense="true"
                 Bordered="true"
                 FixedHeader="true"
                 HorizontalScrollbar="true"
                 Height="calc(100vh - 312px)"
                 RowClassFunc="RowClassFunc"
                 RowClick="OnRowClickAsync"
                 QuickFilter="@_quickFilter">

        <Columns>
            <TemplateColumn Title=""
                            Sortable="false"
                            Filterable="false"
                            HeaderClass="tsc-sticky tsc-sticky-action"
                            CellClass="tsc-sticky tsc-sticky-action">
                <CellTemplate>
                    @if (IsEditing(context.Item))
                    {
                        <div class="tsc-action-cell"
                             @onclick="SuppressRowClick"
                             @onclick:stopPropagation="true">
                            <MudTooltip Text="Cancel edit">
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => CancelEdit(context.Item))" />
                            </MudTooltip>
                        </div>
                    }
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.CID" Title="CID"
                            HeaderClass="tsc-sticky tsc-sticky-cid"
                            CellClass="tsc-sticky tsc-sticky-cid">
                <CellTemplate>
                    <span>@context.Item.CID</span>
                </CellTemplate>
                <FilterTemplate>
                    <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                        Context="@context"
                                        Source="_items"
                                        ValueSelector="@(x => x.CID.ToString())" />
                </FilterTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.FAMILY" Title="FAMILY *"
                            HeaderClass="tsc-sticky tsc-sticky-family"
                            CellClass="tsc-sticky tsc-sticky-family">
                <CellTemplate>
                    <input type="text"
                           class="@CellInputClass(context.Item, FieldFamily, context.Item.FAMILY)"
                           @bind="context.Item.FAMILY"
                           @bind:event="oninput"
                           @onblur="@(() => MarkTouched(FieldFamily))"
                           @onkeydown="@(e => OnKeyDownAsync(e, context.Item))"
                           readonly="@(!IsEditing(context.Item))" />
                </CellTemplate>
                <FilterTemplate>
                    <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                        Context="@context"
                                        Source="_items"
                                        ValueSelector="@(x => x.FAMILY)" />
                </FilterTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.MT_CODE" Title="MT_CODE *"
                            HeaderClass="tsc-sticky tsc-sticky-mtcode"
                            CellClass="tsc-sticky tsc-sticky-mtcode">
                <CellTemplate>
                    <input type="text"
                           class="@CellInputClass(context.Item, FieldMtCode, context.Item.MT_CODE)"
                           @bind="context.Item.MT_CODE"
                           @bind:event="oninput"
                           @onblur="@(() => MarkTouched(FieldMtCode))"
                           @onkeydown="@(e => OnKeyDownAsync(e, context.Item))"
                           readonly="@(!IsEditing(context.Item))" />
                </CellTemplate>
                <FilterTemplate>
                    <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                        Context="@context"
                                        Source="_items"
                                        ValueSelector="@(x => x.MT_CODE)" />
                </FilterTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.DESTINATION" Title="DESTINATION *"
                            HeaderClass="tsc-sticky tsc-sticky-dest"
                            CellClass="tsc-sticky tsc-sticky-dest">
                <CellTemplate>
                    <input type="text"
                           class="@CellInputClass(context.Item, FieldDestination, context.Item.DESTINATION)"
                           @bind="context.Item.DESTINATION"
                           @bind:event="oninput"
                           @onblur="@(() => MarkTouched(FieldDestination))"
                           @onkeydown="@(e => OnKeyDownAsync(e, context.Item))"
                           readonly="@(!IsEditing(context.Item))" />
                </CellTemplate>
                <FilterTemplate>
                    <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                        Context="@context"
                                        Source="_items"
                                        ValueSelector="@(x => x.DESTINATION)" />
                </FilterTemplate>
            </PropertyColumn>

            @foreach (var col in SlotColumns)
            {
                var c = col;
                <TemplateColumn @key="c.Title" Title="@c.Title"
                                Sortable="true"
                                Filterable="true"
                                SortBy="@(x => c.Get(x) ?? string.Empty)">
                    <CellTemplate>
                        <input type="text"
                               class="tsc-cell-input"
                               value="@c.Get(context.Item)"
                               @oninput="@(e => c.Set(context.Item, e.Value?.ToString()))"
                               @onkeydown="@(e => OnKeyDownAsync(e, context.Item))"
                               readonly="@(!IsEditing(context.Item))" />
                    </CellTemplate>
                    <FilterTemplate>
                        <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                            Context="@context"
                                            Source="_items"
                                            ValueSelector="@(x => c.Get(x))" />
                    </FilterTemplate>
                </TemplateColumn>
            }

            <PropertyColumn Property="x => x.IsActive" Title="IsActive">
                <CellTemplate>
                    <MudCheckBox T="bool"
                                 Value="@context.Item.IsActive"
                                 ValueChanged="@(async (bool b) => await OnIsActiveChangedAsync(b, context.Item))"
                                 Dense="true"
                                 Color="Color.Primary" />
                </CellTemplate>
                <FilterTemplate>
                    <ColumnValuesFilter T="ToolSlotConfigurationDTO"
                                        Context="@context"
                                        Source="_items"
                                        ValueSelector="@(x => x.IsActive ? bool.TrueString : bool.FalseString)" />
                </FilterTemplate>
            </PropertyColumn>
        </Columns>

        <PagerContent>
            <MudDataGridPager T="ToolSlotConfigurationDTO"
                              PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>

        <NoRecordsContent>
            <MudText>No records found.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading...</MudText>
        </LoadingContent>
    </MudDataGrid>
</div>

@code {
    private const string FieldFamily = "FAMILY";
    private const string FieldMtCode = "MT_CODE";
    private const string FieldDestination = "DESTINATION";

    private static readonly (string Title,
        Func<ToolSlotConfigurationDTO, string?> Get,
        Action<ToolSlotConfigurationDTO, string?> Set)[] SlotColumns =
    [
        ("FCL1", x => x.FCL1, (x, v) => x.FCL1 = v),
        ("FCL2", x => x.FCL2, (x, v) => x.FCL2 = v),
        ("FCR1", x => x.FCR1, (x, v) => x.FCR1 = v),
        ("FFL1", x => x.FFL1, (x, v) => x.FFL1 = v),
        ("FFL2", x => x.FFL2, (x, v) => x.FFL2 = v),
        ("FFR1", x => x.FFR1, (x, v) => x.FFR1 = v),
        ("FFR2", x => x.FFR2, (x, v) => x.FFR2 = v),
        ("FFR3", x => x.FFR3, (x, v) => x.FFR3 = v),
        ("FFR4", x => x.FFR4, (x, v) => x.FFR4 = v),
        ("RCL1", x => x.RCL1, (x, v) => x.RCL1 = v),
        ("RCR1", x => x.RCR1, (x, v) => x.RCR1 = v),
        ("RCR2", x => x.RCR2, (x, v) => x.RCR2 = v),
        ("RFL1", x => x.RFL1, (x, v) => x.RFL1 = v),
        ("RFR1", x => x.RFR1, (x, v) => x.RFR1 = v),
        ("RFR2", x => x.RFR2, (x, v) => x.RFR2 = v),
    ];

    private MudDataGrid<ToolSlotConfigurationDTO> _grid = null!;
    private List<ToolSlotConfigurationDTO> _items = new();
    private bool _loading = true;
    private string? _search;

    private ToolSlotConfigurationDTO? _editingItem;
    private ToolSlotConfigurationDTO? _editingSnapshot;

    private readonly HashSet<string> _touched = new(StringComparer.Ordinal);

    private bool IsEditing(ToolSlotConfigurationDTO item) =>
        ReferenceEquals(_editingItem, item);

    private string RowClassFunc(ToolSlotConfigurationDTO item, int rowIndex) =>
        ReferenceEquals(_editingItem, item) ? "tsc-editing-row" : string.Empty;

    private string CellInputClass(ToolSlotConfigurationDTO item, string fieldName, string? value) =>
        ReferenceEquals(_editingItem, item)
        && _touched.Contains(fieldName)
        && string.IsNullOrWhiteSpace(value)
            ? "tsc-cell-input tsc-cell-input-error"
            : "tsc-cell-input";

    private void MarkTouched(string fieldName)
    {
        if (_editingItem is null)
            return;
        _touched.Add(fieldName);
    }

    private void MarkAllRequiredTouched()
    {
        _touched.Add(FieldFamily);
        _touched.Add(FieldMtCode);
        _touched.Add(FieldDestination);
    }

    private void SuppressRowClick() { }

    private Func<ToolSlotConfigurationDTO, bool> _quickFilter => x =>
    {
        if (ReferenceEquals(_editingItem, x))
            return true;

        if (string.IsNullOrWhiteSpace(_search))
            return true;

        var s = _search.Trim();

        if (x.CID.ToString().Contains(s, StringComparison.OrdinalIgnoreCase))
            return true;

        if (Has(x.FAMILY) || Has(x.MT_CODE) || Has(x.DESTINATION))
            return true;

        foreach (var col in SlotColumns)
        {
            if (Has(col.Get(x)))
                return true;
        }

        return (x.IsActive ? "true" : "false").Contains(s, StringComparison.OrdinalIgnoreCase);

        bool Has(string? v) => !string.IsNullOrEmpty(v) && v.Contains(s, StringComparison.OrdinalIgnoreCase);
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            _items = await Service.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnRowClickAsync(DataGridRowClickEventArgs<ToolSlotConfigurationDTO> args)
    {
        await TryStartEditAsync(args.Item);
    }

    /// <summary>
    /// Validates the current edit, persists if changed, and clears editing state.
    /// Returns false if validation failed (shows the provided message) or persist failed.
    /// </summary>
    private async Task<bool> TryCommitEditAsync(string? validationMessage = null)
    {
        if (_editingItem is null)
            return true;

        if (!IsRowValid(_editingItem))
        {
            MarkAllRequiredTouched();
            if (validationMessage is not null)
                Snackbar.Add(validationMessage, Severity.Warning);
            return false;
        }

        if (HasChanges(_editingItem, _editingSnapshot))
        {
            if (!await PersistAsync(_editingItem))
                return false;
        }

        _editingItem = null;
        _editingSnapshot = null;
        _touched.Clear();
        return true;
    }

    private async Task TryStartEditAsync(ToolSlotConfigurationDTO item)
    {
        if (ReferenceEquals(_editingItem, item))
            return;

        if (!await TryCommitEditAsync(
                "FAMILY, MT_CODE, and DESTINATION are required. Complete the current row before switching."))
            return;

        _editingSnapshot = Clone(item);
        _editingItem = item;
        _touched.Clear();
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e, ToolSlotConfigurationDTO item)
    {
        if (!ReferenceEquals(_editingItem, item))
            return;

        if (e.Key == "Enter")
        {
            await TryCommitEditAsync(
                "FAMILY, MT_CODE, and DESTINATION are required.");
        }
        else if (e.Key == "Escape")
        {
            CancelEdit(item);
        }
    }

    private async Task OnIsActiveChangedAsync(bool newValue, ToolSlotConfigurationDTO item)
    {
        if (!ReferenceEquals(_editingItem, item))
        {
            await TryStartEditAsync(item);
            if (!ReferenceEquals(_editingItem, item))
                return;
        }

        item.IsActive = newValue;
    }

    private void CancelEdit(ToolSlotConfigurationDTO item)
    {
        if (item.CID == 0)
        {
            _items = _items.Where(x => !ReferenceEquals(x, item)).ToList();
        }
        else if (_editingSnapshot is not null && ReferenceEquals(_editingItem, item))
        {
            RestoreFrom(_editingSnapshot, item);
        }

        _editingItem = null;
        _editingSnapshot = null;
        _touched.Clear();
    }

    private async Task AddNewAsync()
    {
        if (!await TryCommitEditAsync(
                "FAMILY, MT_CODE, and DESTINATION are required on the current row before adding a new one."))
            return;

        var newItem = new ToolSlotConfigurationDTO { IsActive = true };
        _items = _items.Append(newItem).ToList();
        _editingItem = newItem;
        _editingSnapshot = null;
        _touched.Clear();
    }

    private async Task<bool> PersistAsync(ToolSlotConfigurationDTO item)
    {
        if (item.CID == 0)
        {
            var created = await Service.CreateAsync(item);
            var idx = _items.IndexOf(item);
            if (idx >= 0)
            {
                var updated = new List<ToolSlotConfigurationDTO>(_items);
                updated[idx] = created;
                _items = updated.OrderBy(x => x.CID).ToList();
            }
            Snackbar.Add($"Created CID {created.CID}.", Severity.Success);
            return true;
        }
        else
        {
            var ok = await Service.UpdateAsync(item);
            Snackbar.Add(
                ok ? $"Saved CID {item.CID}." : $"Update failed for CID {item.CID}.",
                ok ? Severity.Success : Severity.Error);
            return ok;
        }
    }

    private static bool IsRowValid(ToolSlotConfigurationDTO item) =>
        !string.IsNullOrWhiteSpace(item.FAMILY)
        && !string.IsNullOrWhiteSpace(item.MT_CODE)
        && !string.IsNullOrWhiteSpace(item.DESTINATION);

    private static bool HasChanges(ToolSlotConfigurationDTO current, ToolSlotConfigurationDTO? snapshot)
    {
        if (snapshot is null)
            return true;

        if (!string.Equals(current.FAMILY, snapshot.FAMILY, StringComparison.Ordinal)
            || !string.Equals(current.MT_CODE, snapshot.MT_CODE, StringComparison.Ordinal)
            || !string.Equals(current.DESTINATION, snapshot.DESTINATION, StringComparison.Ordinal)
            || current.IsActive != snapshot.IsActive)
            return true;

        foreach (var col in SlotColumns)
        {
            if (!string.Equals(col.Get(current), col.Get(snapshot), StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    private static ToolSlotConfigurationDTO Clone(ToolSlotConfigurationDTO src)
    {
        var clone = new ToolSlotConfigurationDTO
        {
            CID = src.CID,
            FAMILY = src.FAMILY,
            MT_CODE = src.MT_CODE,
            DESTINATION = src.DESTINATION,
            IsActive = src.IsActive
        };
        foreach (var col in SlotColumns)
            col.Set(clone, col.Get(src));
        return clone;
    }

    private static void RestoreFrom(ToolSlotConfigurationDTO src, ToolSlotConfigurationDTO dst)
    {
        dst.FAMILY = src.FAMILY;
        dst.MT_CODE = src.MT_CODE;
        dst.DESTINATION = src.DESTINATION;
        dst.IsActive = src.IsActive;
        foreach (var col in SlotColumns)
            col.Set(dst, col.Get(src));
    }
}
