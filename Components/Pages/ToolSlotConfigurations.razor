@code {
    private const string FieldFamily = "FAMILY";
    private const string FieldMtCode = "MT_CODE";
    private const string FieldDestination = "DESTINATION";

    private MudDataGrid<ToolSlotConfigurationDTO> _grid = null!;
    private List<ToolSlotConfigurationDTO> _items = new();
    private bool _loading = true;
    private string? _search;

    private ToolSlotConfigurationDTO? _editingItem;
    private ToolSlotConfigurationDTO? _editingSnapshot;

    private readonly HashSet<string> _touched = new(StringComparer.Ordinal);

    private bool IsEditing(ToolSlotConfigurationDTO item) =>
        ReferenceEquals(_editingItem, item);

    private string RowClassFunc(ToolSlotConfigurationDTO item, int rowIndex) =>
        ReferenceEquals(_editingItem, item) ? "tsc-editing-row" : string.Empty;

    private string CellInputClass(ToolSlotConfigurationDTO item, string fieldName, string? value) =>
        ReferenceEquals(_editingItem, item)
        && _touched.Contains(fieldName)
        && string.IsNullOrWhiteSpace(value)
            ? "tsc-cell-input tsc-cell-input-error"
            : "tsc-cell-input";

    private void MarkTouched(string fieldName)
    {
        if (_editingItem is null)
            return;
        _touched.Add(fieldName);
    }

    private void MarkAllRequiredTouched()
    {
        _touched.Add(FieldFamily);
        _touched.Add(FieldMtCode);
        _touched.Add(FieldDestination);
    }

    // Swallows the click on the cancel-button wrapper so it can be paired
    // with @onclick:stopPropagation="true". Without this, clicking Cancel
    // would bubble up to MudDataGrid's RowClick and immediately re-open
    // the edit on the same row.
    private void SuppressRowClick()
    {
    }

    private Func<ToolSlotConfigurationDTO, bool> _quickFilter => x =>
    {
        // Always keep the row currently being edited visible.
        if (ReferenceEquals(_editingItem, x))
            return true;

        if (string.IsNullOrWhiteSpace(_search))
            return true;

        var s = _search.Trim();

        if (x.CID.ToString().Contains(s, StringComparison.OrdinalIgnoreCase))
            return true;

        return Has(x.FAMILY) || Has(x.MT_CODE) || Has(x.DESTINATION)
            || Has(x.FCL1) || Has(x.FCL2) || Has(x.FCR1)
            || Has(x.FFL1) || Has(x.FFL2)
            || Has(x.FFR1) || Has(x.FFR2) || Has(x.FFR3) || Has(x.FFR4)
            || Has(x.RCL1) || Has(x.RCR1) || Has(x.RCR2)
            || Has(x.RFL1) || Has(x.RFR1) || Has(x.RFR2)
            || (x.IsActive ? "true" : "false").Contains(s, StringComparison.OrdinalIgnoreCase);

        bool Has(string? v) => !string.IsNullOrEmpty(v) && v.Contains(s, StringComparison.OrdinalIgnoreCase);
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            _items = await Service.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnRowClickAsync(DataGridRowClickEventArgs<ToolSlotConfigurationDTO> args)
    {
        await TryStartEditAsync(args.Item);
    }

    private async Task TryStartEditAsync(ToolSlotConfigurationDTO item)
    {
        if (ReferenceEquals(_editingItem, item))
            return;

        if (_editingItem is not null)
        {
            if (!IsRowValid(_editingItem))
            {
                MarkAllRequiredTouched();
                Snackbar.Add(
                    "FAMILY, MT_CODE, and DESTINATION are required. Complete the current row before switching.",
                    Severity.Warning);
                return;
            }

            if (HasChanges(_editingItem, _editingSnapshot))
            {
                var saved = await PersistAsync(_editingItem);
                if (!saved)
                    return;
            }

            _editingItem = null;
            _editingSnapshot = null;
            _touched.Clear();
        }

        _editingSnapshot = Clone(item);
        _editingItem = item;
        _touched.Clear();
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e, ToolSlotConfigurationDTO item)
    {
        if (!ReferenceEquals(_editingItem, item))
            return;

        if (e.Key == "Enter")
        {
            if (!IsRowValid(item))
            {
                MarkAllRequiredTouched();
                Snackbar.Add(
                    "FAMILY, MT_CODE, and DESTINATION are required.",
                    Severity.Warning);
                return;
            }

            if (HasChanges(item, _editingSnapshot))
            {
                var saved = await PersistAsync(item);
                if (!saved)
                    return;
            }

            _editingItem = null;
            _editingSnapshot = null;
            _touched.Clear();
        }
        else if (e.Key == "Escape")
        {
            CancelEdit(item);
        }
    }

    private async Task OnIsActiveChangedAsync(bool newValue, ToolSlotConfigurationDTO item)
    {
        if (!ReferenceEquals(_editingItem, item))
        {
            await TryStartEditAsync(item);
            // Edit start was blocked: do not apply the new value.
            if (!ReferenceEquals(_editingItem, item))
                return;
        }

        item.IsActive = newValue;
    }

    private void CancelEdit(ToolSlotConfigurationDTO item)
    {
        if (item.CID == 0)
        {
            // Brand-new row that was never persisted — discard it.
            _items = _items.Where(x => !ReferenceEquals(x, item)).ToList();
        }
        else if (_editingSnapshot is not null && ReferenceEquals(_editingItem, item))
        {
            RestoreFrom(_editingSnapshot, item);
        }

        _editingItem = null;
        _editingSnapshot = null;
        _touched.Clear();
    }

    private async Task AddNewAsync()
    {
        if (_editingItem is not null)
        {
            if (!IsRowValid(_editingItem))
            {
                MarkAllRequiredTouched();
                Snackbar.Add(
                    "FAMILY, MT_CODE, and DESTINATION are required on the current row before adding a new one.",
                    Severity.Warning);
                return;
            }

            if (HasChanges(_editingItem, _editingSnapshot))
            {
                var saved = await PersistAsync(_editingItem);
                if (!saved)
                    return;
            }

            _editingItem = null;
            _editingSnapshot = null;
            _touched.Clear();
        }

        var newItem = new ToolSlotConfigurationDTO { IsActive = true };
        _items = _items.Append(newItem).ToList();
        _editingItem = newItem;
        _editingSnapshot = null;
        _touched.Clear();
    }

    private async Task<bool> PersistAsync(ToolSlotConfigurationDTO item)
    {
        if (item.CID == 0)
        {
            var created = await Service.CreateAsync(item);
            var idx = _items.IndexOf(item);
            if (idx >= 0)
            {
                var updated = new List<ToolSlotConfigurationDTO>(_items);
                updated[idx] = created;
                // Re-sort so the new row drops into its natural CID-ascending
                // position instead of staying pinned at the top where the
                // temporary CID=0 placeholder was prepended by AddNewAsync.
                _items = updated.OrderBy(x => x.CID).ToList();
            }
            Snackbar.Add($"Created CID {created.CID}.", Severity.Success);
            return true;
        }
        else
        {
            var ok = await Service.UpdateAsync(item);
            Snackbar.Add(
                ok ? $"Saved CID {item.CID}." : $"Update failed for CID {item.CID}.",
                ok ? Severity.Success : Severity.Error);
            return ok;
        }
    }

    private static bool IsRowValid(ToolSlotConfigurationDTO item) =>
        !string.IsNullOrWhiteSpace(item.FAMILY)
        && !string.IsNullOrWhiteSpace(item.MT_CODE)
        && !string.IsNullOrWhiteSpace(item.DESTINATION);

    // Brand-new rows (no snapshot) are always treated as dirty so the
    // CreateAsync call still runs. For existing rows, every persisted
    // field is compared against the snapshot taken when the edit started;
    // only a real field change counts as dirty.
    private static bool HasChanges(ToolSlotConfigurationDTO current, ToolSlotConfigurationDTO? snapshot)
    {
        if (snapshot is null)
            return true;

        return !string.Equals(current.FAMILY,      snapshot.FAMILY,      StringComparison.Ordinal)
            || !string.Equals(current.MT_CODE,     snapshot.MT_CODE,     StringComparison.Ordinal)
            || !string.Equals(current.DESTINATION, snapshot.DESTINATION, StringComparison.Ordinal)
            || !string.Equals(current.FCL1,        snapshot.FCL1,        StringComparison.Ordinal)
            || !string.Equals(current.FCL2,        snapshot.FCL2,        StringComparison.Ordinal)
            || !string.Equals(current.FCR1,        snapshot.FCR1,        StringComparison.Ordinal)
            || !string.Equals(current.FFL1,        snapshot.FFL1,        StringComparison.Ordinal)
            || !string.Equals(current.FFL2,        snapshot.FFL2,        StringComparison.Ordinal)
            || !string.Equals(current.FFR1,        snapshot.FFR1,        StringComparison.Ordinal)
            || !string.Equals(current.FFR2,        snapshot.FFR2,        StringComparison.Ordinal)
            || !string.Equals(current.FFR3,        snapshot.FFR3,        StringComparison.Ordinal)
            || !string.Equals(current.FFR4,        snapshot.FFR4,        StringComparison.Ordinal)
            || !string.Equals(current.RCL1,        snapshot.RCL1,        StringComparison.Ordinal)
            || !string.Equals(current.RCR1,        snapshot.RCR1,        StringComparison.Ordinal)
            || !string.Equals(current.RCR2,        snapshot.RCR2,        StringComparison.Ordinal)
            || !string.Equals(current.RFL1,        snapshot.RFL1,        StringComparison.Ordinal)
            || !string.Equals(current.RFR1,        snapshot.RFR1,        StringComparison.Ordinal)
            || !string.Equals(current.RFR2,        snapshot.RFR2,        StringComparison.Ordinal)
            || current.IsActive != snapshot.IsActive;
    }

    private static ToolSlotConfigurationDTO Clone(ToolSlotConfigurationDTO src) => new()
    {
        CID = src.CID,
        FAMILY = src.FAMILY,
        MT_CODE = src.MT_CODE,
        DESTINATION = src.DESTINATION,
        FCL1 = src.FCL1,
